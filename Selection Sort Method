def selection_sort(array):
    if not array:
        return array
    n = len(array)
    for i in range(n):
        min_idx = i
        for j in range(i + 1, n):
            if array[j] < array[min_idx]:
                min_idx = j
        
        if min_idx != i:
            array[i], array[min_idx] = array[min_idx], array[i]
    return array

print(selection_sort([33, 1, 89, 2, 67, 245]))
