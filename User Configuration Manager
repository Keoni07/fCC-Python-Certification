test_settings = {
    'key': 'value',
    'key1': 'value1',
    'key2': 'value2'
}

def add_setting(test_settings, setting_tuple):
    key, value = setting_tuple
    key = key.lower()
    value = value.lower()
    if key in test_settings:
       return f"Setting '{key}' already exists! Cannot add a new setting with this name."
    else:
        test_settings[key] = value
        return f"Setting '{key}' added with value '{value}' successfully!"

def update_setting(update_dict, update_tuple):
    key, value = update_tuple
    key = key.lower()
    value = value.lower()
    if key in update_dict:
        update_dict[key] = value
        return f"Setting '{key}' updated to '{value}' successfully!"
    else:
        return f"Setting '{key}' does not exist! Cannot update a non-existing setting."

def delete_setting(delete_dict, delete_key):
    key = delete_key.lower()
    if key in delete_dict:
        del delete_dict[key]
        return f"Setting '{key}' deleted successfully!"
    else:
        return "Setting not found!"

def view_settings(view_dict):
    if not view_dict:
        return "No settings available."
    
    output = "Current User Settings:"
    for key, value in view_dict.items():
        output += f"\n{key.capitalize()}: {value}"
    return output + "\n"
