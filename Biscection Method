def square_root_bisection(number, tolerance=1e-7, max_iterations=100):
    if number < 0:
        raise ValueError("Square root of negative number is not defined in real numbers")
    
    if number == 0 or number == 1:
        print(f"The square root of {number} is {number}")
        return number
    
    low = 0
    high = max(1.0, number)
    root = None
    
    for i in range(max_iterations):
        mid = (low + high) / 2
        mid_square = mid**2
        
        if abs(low - high) < tolerance:
            root = mid
            break
        elif mid_square < number:
            low = mid
        else:
            high = mid
            
    if root is not None:
        print(f"The square root of {number} is approximately {root}")
        return root
    else:
        print(f"Failed to converge within {max_iterations} iterations")
        return None

print(square_root_bisection(225, 1e-7, 10))
print(square_root_bisection(0.001, 1e-7, 50))
