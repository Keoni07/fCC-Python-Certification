def verify_card_number(card_num):
    digits = [int(d) for d in str(card_num) if d.isdigit()]
    
    for i in range(len(digits) - 2, -1, -2):
        doubled = digits[i] * 2
        if doubled > 9:
            doubled -= 9
        digits[i] = doubled
        
    if sum(digits) % 10 == 0:
        return "VALID!"
    else:
        return "INVALID!"

print(verify_card_number('453914889'))
